{
  // Logging configuration for the application
  "Logging": {
    // Log level settings for different categories
    "LogLevel": {
      // Default log level for all providers when not specified
      "Default": "Information",
      // Log level specifically for Microsoft.AspNetCore namespace
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Specifies which hosts are allowed to access the application
  // "*" means all hosts are allowed
  "AllowedHosts": "*"
}